---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'left' } = Astro.props;
---

<header class:list={['section-heading', `section-heading--${align}`]}>
  {eyebrow && <p class="section-heading__eyebrow">{eyebrow}</p>}
  <h2 class="section-heading__title">{title}</h2>
  {description && <p class="section-heading__description">{description}</p>}
</header>

<style>
  .section-heading {
    display: grid;
    gap: 0.75rem;
    max-width: 44rem;
  }

  .section-heading--center {
    margin-inline: auto;
    text-align: center;
  }

  .section-heading__eyebrow {
    margin: 0;
    color: var(--md-sys-color-primary);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .section-heading__title {
    margin: 0;
    color: var(--md-sys-color-on-surface);
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.05;
  }

  .section-heading__description {
    margin: 0;
    color: var(--md-sys-color-on-surface-variant);
    font-size: 1rem;
    line-height: 1.65;
  }
</style>
