---
import { userConfig } from '../../config';

interface Props {
  project: typeof userConfig.projects[0];
  index: number;
}
const { project, index } = Astro.props;
---

<!-- Import individual web components if you use them, or rely on normal HTML/CSS that mimics M3 -->
<div class="project-card" data-index={index}>
  <div class="card-image" style={`background-image: url(${project.image})`}>
    <div class="overlay">
      <span class="material-symbols-outlined icon-download">download</span>
    </div>
  </div>
  
  <div class="card-content">
    <div class="tags">
      {project.tags.map(tag => (
        <span class="tag">{tag}</span>
      ))}
    </div>
    
    <h3>{project.title}</h3>
    <p>{project.description}</p>
    
    <div class="card-actions">
      <a href={project.link} class="btn-primary ripple">
        <span>Ver Proyecto</span>
        <md-ripple></md-ripple>
      </a>
    </div>
  </div>
</div>

<script>
  import '@material/web/ripple/ripple.js';
</script>

<style>
  .project-card {
    background-color: var(--md-sys-color-surface-container-low, #1e1e1e);
    border-radius: 28px; /* M3 large shape */
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    transition: transform 0.3s cubic-bezier(0.2, 0, 0, 1), box-shadow 0.3s ease;
    cursor: pointer;
    border: 1px solid var(--md-sys-color-outline-variant, #444);
    opacity: 0; /* Starter state for GSAP */
    transform: translateY(30px);
  }
  
  .project-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.2);
    border-color: var(--md-sys-color-primary, #80ced6);
  }

  .card-image {
    width: 100%;
    height: 200px;
    background-size: cover;
    background-position: center;
    position: relative;
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  
  .project-card:hover .overlay {
    opacity: 1;
  }
  
  .icon-download {
    color: white;
    font-size: 3rem;
    transform: translateY(20px);
    transition: transform 0.3s cubic-bezier(0.2, 0, 0, 1);
  }
  
  .project-card:hover .icon-download {
    transform: translateY(0);
  }

  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 4px 12px;
    border-radius: 16px;
    background-color: var(--md-sys-color-secondary-container, #334b4f);
    color: var(--md-sys-color-on-secondary-container, #cce8eb);
  }

  h3 {
    margin: 0 0 0.5rem 0;
    color: var(--md-sys-color-on-surface, #e3e3e3);
    font-size: 1.25rem;
    letter-spacing: -0.01em;
  }

  p {
    margin: 0;
    color: var(--md-sys-color-on-surface-variant, #c4c7c5);
    font-size: 0.875rem;
    line-height: 1.5;
    flex: 1;
  }

  .card-actions {
    margin-top: 1.5rem;
    display: flex;
    justify-content: flex-end;
  }

  .btn-primary {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 1.5rem;
    height: 40px;
    border-radius: 20px;
    background-color: var(--md-sys-color-primary, #80ced6);
    color: var(--md-sys-color-on-primary, #00363a);
    font-weight: 500;
    font-size: 0.875rem;
    overflow: hidden;
    --md-ripple-hover-color: var(--md-sys-color-on-primary, #000);
    --md-ripple-pressed-color: var(--md-sys-color-on-primary, #000);
  }
</style>
