---
import { userConfig } from '../site-config';
---

<script>
  import { applyTheme, themeFromSourceColor } from '@material/material-color-utilities';

  let defaultMode = 'dark';

  function buildThemeCss(hexColor) {
    const colorInt = parseInt(hexColor.replace('#', ''), 16);
    const argbColor = colorInt | 0xff000000;
    const theme = themeFromSourceColor(argbColor);
    const dummy = document.createElement('div');

    applyTheme(theme, { target: dummy, dark: false });
    const lightVariables = dummy.getAttribute('style');

    applyTheme(theme, { target: dummy, dark: true });
    const darkVariables = dummy.getAttribute('style');

    return `
      :root { ${lightVariables} }
      :root.dark { ${darkVariables} }
      @media (prefers-color-scheme: dark) {
        :root:not(.light) { ${darkVariables} }
      }
    `;
  }

  function applyPastelTheme(hexColor) {
    let styleTag = document.getElementById('md3-dynamic-theme');

    if (!styleTag) {
      styleTag = document.createElement('style');
      styleTag.id = 'md3-dynamic-theme';
      document.head.appendChild(styleTag);
    }

    styleTag.textContent = buildThemeCss(hexColor);
    document.documentElement.removeAttribute('style');
    document.documentElement.classList.toggle('dark', defaultMode === 'dark');
  }

  function initTheme() {
    const themeData = document.querySelector('div.hidden[data-theme-color]');
    const baseColor = themeData?.dataset.themeColor || '#80ced6';
    defaultMode = themeData?.dataset.themeMode || 'dark';

    applyPastelTheme(baseColor);

    const picker = document.getElementById('theme-picker');

    if (picker instanceof HTMLInputElement) {
      picker.value = baseColor;
      picker.oninput = (event) => {
        const nextColor = event.target instanceof HTMLInputElement ? event.target.value : baseColor;
        applyPastelTheme(nextColor);
      };
    }
  }

  function ensureTransitionStyles() {
    if (document.getElementById('md3-transition-theme')) {
      return;
    }

    const style = document.createElement('style');
    style.id = 'md3-transition-theme';
    style.textContent = `
      html, body {
        transition: background-color 0.45s ease, color 0.45s ease;
      }
      body *, body *::before, body *::after {
        transition:
          background-color 0.28s ease,
          border-color 0.28s ease,
          color 0.28s ease,
          box-shadow 0.28s ease;
      }
    `;
    document.head.appendChild(style);
  }

  initTheme();
  ensureTransitionStyles();
  document.addEventListener('astro:after-swap', initTheme);
</script>

<div
  class="hidden"
  data-theme-color={userConfig.theme.baseColor}
  data-theme-mode={userConfig.theme.defaultMode}
></div>
